RewriteEngine On

# Nu rescrie fisierele statice existente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# URL curate -> fisiere HTML
RewriteRule ^login$ login.html [L]
RewriteRule ^register$ register.html [L]
RewriteRule ^forgot-password$ forgotpassword.html [L]

# Fallback -> landing page
RewriteRule ^(.*)$ landingpage.html [QSA,L]